{
  "camera": {
    "iso": "800",
    "shutterSpeed": "1/125",
    "aperture": "5.6",
    "pictureProfile": "standard",
    "captureTarget": "card",
    "persistentMovieMode": false,
    "paths": {
      "iso": "iso",
      "shutterSpeed": "shutterspeed",
      "aperture": "f-number",
      "pictureProfile": "/main/capturesettings/picturestyle",
      "autofocus": "autofocusdrive",
      "captureTarget": "capturetarget"
    },
    "startupConfigs": [
      { "path": "whitebalance", "value": "auto" }
    ],
    "video": {
      "iso": "800",
      "shutterSpeed": "1/60",
      "aperture": "2.8",
      "paths": {
        "iso": "movieiso",
        "shutterSpeed": "movieshutterspeed",
        "aperture": "movief-number"
      },
      "startupConfigs": []
    },
    "movie": {
      "startConfigPath": "movie",
      "startValue": "1",
      "stopConfigPath": "movie",
      "stopValue": "0",
      "fileExtension": "mov"
    }
  },
  "preview": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "platform": {
      "linux": {
        "inputFormat": "v4l2",
        "device": "/dev/video0"
      },
      "darwin": {
        "inputFormat": "avfoundation",
        "device": "0:none",
        "pixelFormat": "uyvy422"
      }
    },
    "crop": {
      "enabled": false,
      "x": 0,
      "y": 0,
      "width": 1920,
      "height": 1080
    }
  },
  "app": {
    "port": 3000,
    "sessionsDir": "./sessions",
    "countdownSeconds": 10,
    "shutterOffsetMs": 0,
    "cameraPosition": "above",
    "lookText": "Look here!",
    "enableEmail": true,
    "enablePhone": false,
    "mode": "dev",
    "eventName": "Your Event Name",
    "screensaverTimeoutSeconds": 60,
    "generateShareId": false,
    "periodicAutofocus": false,
    "galleryServer": {
      "enabled": false,
      "baseUrl": "http://localhost:4000",
      "authToken": "change-me-to-a-secure-random-token",
      "resize": {
        "enabled": false,
        "mode": "preset",
        "preset": "socialMedia",
        "longEdge": 1920,
        "percentage": 50,
        "quality": 85
      }
    },
    "notifications": {
      "enabled": false,
      "from": { "email": "Photobooth <noreply@example.com>", "sms": "+15555550123" },
      "subject": "Your photos from {eventName}",
      "emailTemplate": "<p>Thanks for stopping by{eventNameSuffix}!</p><p>Your photos: <a href=\"{shareUrl}\">{shareUrl}</a></p>",
      "smsTemplate": "Your photos{eventNameSuffix}:\n{shareUrl}",
      "smtp": { "host": "", "port": 587, "secure": false, "user": "", "pass": "" },
      "twilio": { "accountSid": "", "authToken": "", "from": "+15555550123" },
      "options": {
        "channel": "preferEmail",
        "deleteAfterSend": false,
        "skipAlreadySent": true,
        "skipVideoSessions": false,
        "maxAgeDays": 0,
        "dryRun": false,
        "continueOnError": true,
        "mode": "all",
        "retryQueuePath": "./scripts/sendShares.retry.json",
        "runInitialSweep": true
      }
    },
    "video": {
      "enabled": false,
      "maxRecordSeconds": 60,
      "countdownSeconds": 3,
      "startOffsetMs": 0,
      "prompts": [
        "What's your favorite memory with them?",
        "Share a wish for the future.",
        "Tell a funny story."
      ],
      "promptsPersistDuringRecording": true,
      "audio": {
        "externalMic": {
          "enabled": false,
          "ffmpegInput": "-f alsa -i hw:1,0",
          "sampleRate": 48000,
          "channels": 2
        }
      },
      "share": {
        "enabled": true,
        "upload": true,
        "uploadTiming": "immediate"
      }
    }
  },
  "admin": {
    "password": "change-me-to-a-secure-random-token",
    "sessionTtlMinutes": 240
  }
}
