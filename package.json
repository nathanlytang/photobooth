{
  "name": "photobooth",
  "version": "1.0.0",
  "description": "Photobooth with HDMI capture live preview and gphoto2 camera control",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:css": "tailwindcss -i src/input.css -o public/tailwind.css",
    "watch:css": "tailwindcss -i src/input.css -o public/tailwind.css --watch"
  },
  "keywords": [
    "photobooth",
    "gphoto2"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "nanoid": "^3.3.11",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
