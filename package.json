{
  "name": "photobooth",
  "version": "2.0.0",
  "description": "Photobooth with HDMI capture live preview and gphoto2 camera control",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node --import tsx server/index.ts",
    "preview": "vite preview",
    "notify": "tsx scripts/sendShares.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron": "electron electron/main.cjs",
    "kiosk": "concurrently -k -n server,electron -c blue,magenta \"pnpm start\" \"electron electron/main.cjs\"",
    "kiosk:dev": "KIOSK_URL=http://localhost:5173 KIOSK_DEV=1 electron electron/main.cjs",
    "build:server": "node scripts/build-server.mjs",
    "dist:mac": "pnpm build && pnpm build:server && electron-builder --mac"
  },
  "build": {
    "appId": "com.photobooth.kiosk",
    "productName": "PhotoBooth",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/server",
        "to": "server"
      },
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "config.example.json",
        "to": "config.example.json"
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dir"
      ]
    }
  },
  "keywords": [
    "photobooth",
    "gphoto2"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "nanoid": "^3.3.11",
    "nodemailer": "^9.0.1",
    "react-simple-wysiwyg": "^3.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.24.0",
    "lucide-react": "^0.468.0",
    "qrcode-generator": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
